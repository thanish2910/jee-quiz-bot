# Copy this to .env and fill in your values
# On Railway: set these in the dashboard under Variables tab

TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_IDS=your_telegram_user_id

# Cloudinary (rotate your secret first at cloudinary.com!)
IMAGE_BACKEND=cloudinary
CLOUDINARY_CLOUD_NAME=jee_bot_thta
CLOUDINARY_API_KEY=154243649693424
CLOUDINARY_API_SECRET=your_NEW_secret_after_rotating

# Bot settings
BOT_USERNAME=YourBotUsername
IMAGE_BACKEND=cloudinary

# Rate limits (optional — defaults are fine)
RATE_MSG_LIMIT=10
RATE_MSG_WINDOW=10
RATE_CB_LIMIT=15
BAN_DURATION=300

# File paths (Railway uses ephemeral storage — data resets on redeploy)
# Use a persistent volume in Railway dashboard for these to survive redeploys
SEED_FILE=seed_questions.json
ADDED_FILE=added_questions.json
SUGGESTED_FILE=suggested_questions.json
LEADERBOARD_FILE=leaderboard.json
KNOWN_USERS_FILE=known_users.json
AUTOPOST_FILE=autopost_config.json
